# .dockerignore — exclude files that must never be baked into the Docker image

# Secrets — must be injected via env_file / environment in docker-compose.yml,
# never baked into the image layer where they would be readable in image history.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dev tooling
node_modules
.next
.git
*.log
npm-debug.log*

# Test / editor artefacts
tests/e2e/results
playwright-report
coverage
.DS_Store
