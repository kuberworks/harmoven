// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// T1.2 — Harmoven v1 complete Prisma schema
//
// ⚠  User model is GENERATED by `npx @better-auth/cli generate`.
//    Do NOT define it manually. Merge CLI output into this file (see comment
//    below at the Better Auth section). After merging, run:
//      npx prisma migrate dev --name init
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider = "postgresql" // "sqlite" for Electron builds — controlled via DEPLOYMENT_MODE
  // url is configured in prisma.config.ts at the project root (Prisma 7+)
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER   // maps to better-auth's "user" role value
  VIEWER
}

enum UiLevel {
  GUIDED
  STANDARD
  ADVANCED
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SUSPENDED
  PAUSED // Amendment 63 — manual pause by user
}

enum NodeStatus {
  PENDING
  RUNNING
  BLOCKED
  FAILED
  ESCALATED
  SKIPPED
  COMPLETED
  DEADLOCKED
  INTERRUPTED // Amendment 65 — streaming abort, awaiting user decision
}

enum HumanGateStatus {
  OPEN
  RESOLVED
  TIMED_OUT
}

// Amendment 60 — GitWorktree.layer must be an enum (not a free text String)
// to get DB-level validation. Values mirror the layer hierarchy in appScaffolding.
enum WorktreeLayer {
  db
  api
  ui
  infra
  test
}

enum TriggerType {
  CRON
  FILE_WATCHER
  WEBHOOK
}

enum CredentialType {
  HTTP_BEARER
  HTTP_BASIC
  HEADER
  QUERY_PARAM
  OAUTH2
}

// ─── User & Auth tables (Better Auth 1.5.6) ──────────────────────────────────
//
// Models were produced by inspecting the plugin schemas of better-auth 1.5.6:
//   plugins: admin(), twoFactor()
//   additionalFields in lib/auth.ts: ui_score, ui_level, expert_mode,
//     preferences, ui_locale (Am.86), transparency_language (Am.87)
//
// The canonical source of truth is prisma/better-auth.prisma — kept alongside
// so future runs of `npx @better-auth/cli generate` can be diffed against it.
//
// Relations added by this application: runs, project_memberships,
//   user_preferences, installed_packs.

model User {
  id                    String    @id
  name                  String
  email                 String    @unique
  emailVerified         Boolean
  image                 String?
  createdAt             DateTime
  updatedAt             DateTime
  // Admin plugin — role/ban management
  role                  String?
  banned                Boolean?
  banReason             String?
  banExpires            DateTime?
  // Application additionalFields (lib/auth.ts)
  ui_score              Int       @default(0)
  ui_level              String    @default("GUIDED")
  expert_mode           Boolean   @default(false)
  preferences           String    @default("{}")
  // Amendment 86 — UI language: 'en' | 'fr' | null (auto-detect)
  ui_locale             String?
  // Amendment 87 — transparency feed language; null = follows ui_locale
  transparency_language String?
  // twoFactor plugin — twoFactorEnabled on User (Better Auth ≥1.3.26)
  twoFactorEnabled      Boolean   @default(false)
  // Relations
  sessions              Session[]
  accounts              Account[]
  two_factor            TwoFactor?
  passkeys              Passkey[]
  api_keys              BetterAuthApiKey[]
  runs                  Run[]
  project_memberships   ProjectMember[]
  user_preferences      UserPreference[]
  installed_packs       InstalledPack[]
  pipeline_templates    PipelineTemplate[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@map("verification")
}

// twoFactor plugin
model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

// ─── Passkey (FIDO2/WebAuthn) — @better-auth/passkey ─────────────────────────
// Generated from @better-auth/passkey@1.5.6 schema definition.
// One row per registered authenticator (device). A user may have multiple.

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String    @unique
  counter      Int
  deviceType   String    // "singleDevice" | "multiDevice"
  backedUp     Boolean
  transports   String?   // comma-separated list from AuthenticatorTransport
  aaguid       String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@map("passkey")
}

// ─── API Key — @better-auth/api-key ──────────────────────────────────────────
// User-level API keys managed via Better Auth (distinct from ProjectApiKey which
// is the project-scoped RBAC key system in lib/auth/project-api-key.ts).
// Table name "apikey" is hardcoded by the plugin (API_KEY_TABLE_NAME const).

model BetterAuthApiKey {
  id                 String    @id @default(cuid())
  configId           String    @default("default")
  name               String?
  start              String?   // first 4 chars of the raw key (display only)
  referenceId        String
  prefix             String?
  key                String    @unique   // hashed key stored here
  refillInterval     Int?
  refillAmount       Int?
  lastRefillAt       DateTime?
  enabled            Boolean   @default(true)
  rateLimitEnabled   Boolean   @default(true)
  rateLimitTimeWindow Int?
  rateLimitMax       Int?
  requestCount       Int       @default(0)
  remaining          Int?
  lastRequest        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  permissions        String?   // JSON-encoded string[] of allowed permissions
  metadata           Json?
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([configId])
  @@index([referenceId])
  @@map("apikey")
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id               String    @id @default(uuid())
  name             String
  description      String?
  domain_profile   String    // data_reporting | app_scaffolding | ...
  config           Json      @default("{}")   // project-level AGENTS.md overrides
  confidentiality  String    @default("MEDIUM")
  regulatory_ctx   Json      @default("[]")
  created_by       String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  // Amendment 83 — Config-as-Code git versioning
  config_git_hash  String?   // hash of last committed orchestrator.yaml version
  config_git_at    DateTime? // timestamp of last git commit

  // Soft-delete — Amendment 40 (DELETE /api/projects/:id)
  archived_at      DateTime? // null = active; non-null = archived

  runs               Run[]
  triggers           Trigger[]
  memory_resources   MemoryResource[]
  members            ProjectMember[]
  roles              ProjectRole[]
  api_keys           ProjectApiKey[]
  credentials        ProjectCredential[]
  git_worktrees      GitWorktree[]
  pipeline_templates PipelineTemplate[]
}

// ─── Runs ─────────────────────────────────────────────────────────────────────

model Run {
  // H-03 / Spec T1.2: Run IDs MUST be UUID v7 (time-sortable) for v2 federation.
  // @default(uuid()) generates v4 — it is kept as a Prisma fallback only.
  // ALL application-level Run creation MUST call uuidv7() and pass the id explicitly.
  // Never rely on Prisma's default here: use `db.run.create({ data: { id: uuidv7(), … } })`.
  id                   String    @id @default(uuid())
  project_id           String
  project              Project   @relation(fields: [project_id], references: [id])
  created_by           String?   // null for trigger-initiated runs
  // Marketplace v2 — Smart Import (A.4.2)
  // run_type: null = normal run; 'marketplace_import' = phantom LLM call (excluded from normal lists)
  run_type             String?   // null | 'marketplace_import'
  // triggered_by: userId for phantom runs; null for normal runs
  triggered_by         String?
  trigger_id           String?
  status               RunStatus @default(PENDING)
  suspended_reason     String?   // human_gate | crash_recovery | budget_exceeded |
                                 // no_compatible_model | user_cancelled
  domain_profile       String
  task_input           Json
  dag                  Json      // full DAG from Planner
  run_config           Json
  transparency_mode    Boolean   @default(false) // Amendment 61
  user_injections      Json      @default("[]")  // Amendment 64 — UserInjection[]
  budget_usd           Decimal?  @db.Decimal(10, 4)
  budget_tokens        Int?
  cost_actual_usd      Decimal   @default(0) @db.Decimal(10, 4)
  tokens_actual        Int       @default(0)
  primary_artifact_id  String?
  confidentiality      String?
  regulatory_contexts  Json?
  started_at                DateTime?
  completed_at              DateTime?
  paused_at                 DateTime? // Amendment 63 — manual pause timestamp
  last_completed_node_at    DateTime? // Amendment 64 — for context injection filtering
  created_at                DateTime  @default(now())
  metadata             Json      @default("{}")

  // Amendment 85 — KPIs & ROI tracking (filled by user after completion)
  estimated_hours_saved Float?   // user-declared (optional)
  user_rating           Int?     // 1–5 stars (optional)
  business_value_note   String?  // free-text ROI context (optional)
  task_input_chars      Int      @default(0) // computed at creation

  // RGPD Art.5 §1 e) — Data retention TTL (RGPD-04).
  // Set at creation time to created_at + DATA_RETENTION_DAYS (default 90).
  // When the maintenance job fires (daily 03:30) and this date is in the past,
  // task_input, user_injections and Node content are purged.
  // Null after purge to prevent re-processing.
  data_expires_at      DateTime?

  // Pipeline template — optional FK to PipelineTemplate used to seed this run's DAG
  pipeline_template_id  String?
  pipeline_template     PipelineTemplate? @relation(fields: [pipeline_template_id], references: [id])

  user         User?         @relation(fields: [created_by], references: [id])
  nodes        Node[]
  handoffs     Handoff[]
  audit_entries AuditLog[]
  human_gates  HumanGate[]
  actor_stats  RunActorStats?
  eval_results EvalResult[]
  critical_reviews CriticalReviewResult[]
  prompt_summaries PromptSummary[]

  // Run chaining — a run may depend on the outputs of 1..5 parent runs.
  parent_links RunDependency[] @relation("RunAsChild")   // parents of this run
  child_links  RunDependency[] @relation("RunAsParent")  // children spawned from this run

  artifacts    RunArtifact[]

  @@index([project_id])
  @@index([status])
  @@index([created_by])
  @@index([run_type])
  @@index([pipeline_template_id])
  @@index([data_expires_at])
}

// ─── Run chaining — join table ────────────────────────────────────────────────
// Allows a run to depend on the outputs of multiple parent runs (up to 5).
// Cascade delete: removing a run removes all dependency rows referencing it.

model RunDependency {
  child_run_id   String
  parent_run_id  String
  child_run      Run      @relation("RunAsChild",  fields: [child_run_id],  references: [id], onDelete: Cascade)
  parent_run     Run      @relation("RunAsParent", fields: [parent_run_id], references: [id], onDelete: Cascade)
  created_at     DateTime @default(now())

  @@id([child_run_id, parent_run_id])
  @@index([parent_run_id])
}

// ─── Nodes ───────────────────────────────────────────────────────────────────

model Node {
  id                 String     @id @default(uuid())
  run_id             String
  run                Run        @relation(fields: [run_id], references: [id])
  node_id            String     // "n1", "n2" — from DAG definition
  agent_type         String     // CLASSIFIER | PLANNER | WRITER | REVIEWER | QA | DEVOPS
  status             NodeStatus @default(PENDING)
  llm_profile_id     String?
  llm_assigned_at    DateTime?
  started_at         DateTime?
  completed_at       DateTime?
  interrupted_at     DateTime?  // Amendment 65 — streaming abort timestamp
  interrupted_by     String?    // "user" | "system"
  last_heartbeat     DateTime?
  retries            Int        @default(0)
  handoff_in         Json?
  handoff_out        Json?
  partial_output     String?    // Amendment 65 — accumulated streaming text (Clob)
  partial_updated_at DateTime?  // Amendment 65 — last flush timestamp
  cost_usd           Decimal    @default(0) @db.Decimal(10, 4)
  tokens_in          Int        @default(0)
  tokens_out         Int        @default(0)
  error              String?
  metadata           Json       @default("{}")

  @@index([run_id])
  @@index([status])
  // last_heartbeat index — converted to partial (WHERE status='RUNNING') in migration SQL
  // for orphan detection. See migration down.sql for the replacement statement.
  @@index([last_heartbeat])
}

// ─── Prompt Summary – Lightweight audit trail ─────────────────────────────────
// Amendment 86 – After each node execution, capture:
// - Agent type + domain profile at execution time
// - Upstream node references (to reconstruct context)
// - Approximate token counts (for optimization)
// Does NOT store full prompts (see analysis: prompt-storage.md)
// Enables audit trail + basic transparency without GDPR/storage burden

model PromptSummary {
  id               String    @id @default(uuid())
  run_id           String
  run              Run       @relation(fields: [run_id], references: [id])
  node_id          String    // "n1", "n2" etc
  agent_type       String    // CLASSIFIER | PLANNER | WRITER | REVIEWER | SMOKE_TEST | REPAIR | CRITICAL_REVIEW
  domain_profile   String    // data_reporting | app_scaffolding | generic | ... as executed
  
  // Execution context snapshot
  execution_context Json    // {profile_detected_at, complexity, expected_output_type, task_input_truncated, upstream_nodes}
  
  // Approximate token consumption (for cost tracking)
  estimated_tokens_in  Int?     // rough estimate before execution
  estimated_tokens_out Int?     // rough estimate based on output_type
  
  // Metadata for reconstruction attempts
  upstream_handoff_hash String?  // SHA256 of concatenated upstream handoff_outs
  serialization_version String   // "1.0" for future-proofing
  
  // Timestamps
  created_at       DateTime  @default(now())
  
  @@index([run_id])
  @@index([node_id])
  @@unique([run_id, node_id])
}

// ─── Handoffs ────────────────────────────────────────────────────────────────

model Handoff {
  id              String   @id @default(uuid())
  run_id          String
  run             Run      @relation(fields: [run_id], references: [id])
  sequence_number Int      @default(autoincrement())
  source_agent    String
  source_node_id  String?
  target_agent    String
  payload         Json     // immutable once written
  created_at      DateTime @default(now())

  @@unique([run_id, sequence_number])
  @@index([run_id])
}

// ─── Human Gates ─────────────────────────────────────────────────────────────

model HumanGate {
  id         String          @id @default(uuid())
  run_id     String
  run        Run             @relation(fields: [run_id], references: [id])
  reason     String          // low_confidence | reviewer_findings | budget_warning | ...
  data       Json
  status     HumanGateStatus @default(OPEN)
  decision   String?         // approve | modify | replay_node | abort
  decided_by String?
  opened_at  DateTime        @default(now())
  timeout_at DateTime?
  decided_at DateTime?

  @@index([run_id])
}

// ─── Audit Log (immutable) ───────────────────────────────────────────────────
// UPDATE/DELETE are blocked at DB level via PostgreSQL rules — see migration SQL.
// actor: user_id | "trigger/{id}" | "system" — NOT a FK (can be non-user values).

model AuditLog {
  // SEC-M-04: No schema-level default — all call sites pass `id: uuidv7()` explicitly,
  // which gives time-sortable IDs for forensic log ordering by primary key.
  // Removing @default(uuid()) here enforces that no future caller skips the explicit id.
  id          String   @id
  timestamp   DateTime @default(now())
  run_id      String?
  run         Run?     @relation(fields: [run_id], references: [id])
  node_id     String?
  actor       String   // user_id | "trigger/{id}" | "system"
  action_type String
  payload     Json?

  @@index([run_id])
  @@index([actor])
  @@index([timestamp])
}

// ─── Triggers ────────────────────────────────────────────────────────────────

model Trigger {
  id            String      @id @default(uuid())
  project_id    String
  project       Project     @relation(fields: [project_id], references: [id])
  type          TriggerType
  name          String
  config        Json        // type-specific config (cron, file pattern, etc.)
  template_id   String?
  task_overrides Json       @default("{}")
  supervision   String      @default("auto_deliver_if_approved")
  notify        Json        @default("{}")
  enabled       Boolean     @default(true)
  created_by    String
  created_at    DateTime    @default(now())
  last_fired_at DateTime?
  run_count     Int         @default(0)
}

// ─── LLM Profiles ────────────────────────────────────────────────────────────

model LlmProfile {
  id                        String   @id // e.g. "claude-opus-4-6"
  provider                  String
  model_string              String
  tier                      String   // fast | balanced | powerful
  context_window            Int
  cost_per_1m_input_tokens  Decimal  @db.Decimal(10, 4)
  cost_per_1m_output_tokens Decimal  @db.Decimal(10, 4)
  jurisdiction              String   // us | eu | cn | local
  trust_tier                Int      // 1 | 2 | 3
  enabled                   Boolean  @default(true)
  modality                  String   @default("text")  // "text" | "image" | "multimodal"
  task_type_affinity        String[] // task types this model excels at
  config                    Json     @default("{}")
}

// ─── MCP Skills ──────────────────────────────────────────────────────────────

model McpSkill {
  id           String    @id @default(uuid())
  name         String
  source_url   String?
  source_type  String    // official | git | local | upload | registry
  version      String?
  approved_by  String?
  approved_at  DateTime?
  scan_status  String    @default("pending") // pending | passed | failed
  scan_report  Json?
  enabled      Boolean   @default(false)
  config       Json      @default("{}")
  installed_at DateTime  @default(now())

  // Marketplace v2 additions
  capability_type      String?   // domain_pack | mcp_skill | harmoven_agent | js_ts_plugin | slash_command
  pack_id              String?   @unique // validated slug /^[a-z0-9_]{1,64}$/
  author               String?
  tags                 String[]  @default([])
  registry_id          String?   // FK reference label (denormalised — MarketplaceRegistry.id)
  upload_sha256        String?   // SHA-256 of uploaded .hpkg file bytes (traceability, B.3.2 V13)
  source_ref           String?   // resolved branch/tag/commit ref at import time
  installed_sha256     String?   // SHA-256 of primary file at last install or update
  last_update_check_at DateTime? // last time cron checked this skill
  pending_update       Json?     // { changed_fields, new_sha256, detected_at } — written by cron

  @@index([source_type])
  @@index([last_update_check_at])
}

// ─── Codebase Memory ─────────────────────────────────────────────────────────

model MemoryResource {
  id            String    @id @default(uuid())
  project_id    String?
  project       Project?  @relation(fields: [project_id], references: [id])
  namespace     String    // "memory://project/.../auth"
  uri           String    @unique
  l0_abstract   String    // ~50 tokens — always in context
  l1_overview   String?   // ~500 tokens — loaded on match
  l2_content    String?   // full content — explicit only
  content_hash  String
  last_written  DateTime  @default(now())
  last_accessed DateTime?
  access_count  Int       @default(0)
  tags          String[]
  metadata      Json      @default("{}")

  @@index([project_id, namespace])
}

// ─── Project Roles (Amendment 78) ────────────────────────────────────────────
// Replaces the old ProjectRole enum with a flexible model.
// Built-in roles (is_builtin=true, project_id=null): viewer, operator, user,
//   user_with_costs, developer, admin, instance_admin
// Custom roles: project-scoped, extend a built-in (permissions are additive).

model ProjectRole {
  id           String   @id @default(uuid())
  project_id   String?  // null = global built-in role
  name         String   // slug: 'viewer' | 'operator' | custom
  display_name String
  extends      String?  // built-in role slug to extend (permissions additive)
  permissions  String[] // Permission[] values added on top of extends
  is_builtin   Boolean  @default(false)
  created_at   DateTime @default(now())
  created_by   String?

  project  Project?        @relation(fields: [project_id], references: [id])
  members  ProjectMember[]
  api_keys ProjectApiKey[]

  @@unique([project_id, name])
}

// ─── Project Membership ───────────────────────────────────────────────────────

model ProjectMember {
  project_id String
  user_id    String
  role_id    String   // FK to ProjectRole (Amendment 78 — replaces role enum)
  added_by   String
  added_at   DateTime @default(now())

  project Project     @relation(fields: [project_id], references: [id])
  user    User        @relation(fields: [user_id], references: [id])
  role    ProjectRole @relation(fields: [role_id], references: [id])

  @@id([project_id, user_id])
  @@index([user_id])
}

// ─── Project API Keys ─────────────────────────────────────────────────────────
// Format: hv1_{32 chars}. better-auth plugin used for key generation only.
// key_hash stores SHA-256 of the full key — the raw key is never persisted.

model ProjectApiKey {
  id         String    @id @default(uuid())
  project_id String
  role_id    String
  name       String    // human label: "Acme Integration"
  key_hash   String    @unique // SHA-256(hv1_{32 chars})
  created_by String
  created_at DateTime  @default(now())
  last_used  DateTime?
  expires_at DateTime?
  revoked_at DateTime?

  project Project     @relation(fields: [project_id], references: [id])
  role    ProjectRole @relation(fields: [role_id], references: [id])

  @@index([project_id])
}

// ─── Project Credentials ──────────────────────────────────────────────────────

model ProjectCredential {
  id           String         @id @default(uuid())
  project_id   String
  project      Project        @relation(fields: [project_id], references: [id])
  name         String         // symbolic name — e.g. "STRIPE_API_KEY"
  value_enc    String         // AES-256-GCM encrypted — NEVER returned by API
  type         CredentialType
  inject_as    String         // header name or query param name
  inject_fmt   String         // "Bearer {value}" | "{value}"
  host_pattern String         // "api.stripe.com" — injection scoped to this host
  path_pattern String?        // optional path restriction
  tool_scope   String[]       // tool IDs allowed — [] = all project tools
  created_by   String
  created_at   DateTime       @default(now())
  last_used_at DateTime?
  rotated_at   DateTime?
  oauth_token  OAuthToken?

  @@unique([project_id, name])
}

// ─── OAuth Tokens ─────────────────────────────────────────────────────────────

model OAuthToken {
  id                String            @id @default(uuid())
  credential_id     String            @unique
  credential        ProjectCredential @relation(fields: [credential_id], references: [id])
  access_token_enc  String            // AES-256-GCM encrypted
  refresh_token_enc String            // AES-256-GCM encrypted
  expires_at        DateTime
  token_url         String
  scope             String?
  updated_at        DateTime          @updatedAt
}

// ─── Webhook Idempotency ──────────────────────────────────────────────────────
// Purge entries older than 24h via cron — prevents table bloat.

model WebhookDelivery {
  id          String   @id @default(uuid())
  delivery_id String   @unique // X-Webhook-Delivery header value
  trigger_id  String
  received_at DateTime @default(now())

  @@index([received_at])
}

// ─── User Preferences (Optimizer) ────────────────────────────────────────────

model UserPreference {
  id          String    @id @default(uuid())
  user_id     String
  user        User      @relation(fields: [user_id], references: [id])
  project_id  String?
  preference  String    // e.g. "no_tables_in_output", "output_language_fr"
  evidence    String
  confidence  Decimal   @db.Decimal(4, 2)
  applied_at  DateTime  @default(now())
  reverted_at DateTime?

  @@index([user_id, project_id])
}

// ─── Installed Packs (Amendment 67) ──────────────────────────────────────────

model InstalledPack {
  id              String   @id @default(uuid())
  workspace_id    String?  // null = user-level
  user_id         String
  pack_id         String   // marketplace id or local slug
  source          String   // marketplace | import | user_created
  version         String
  update_policy   String   @default("notify") // auto | notify | manual
  pinned_version  String?
  local_overrides Json?    // diff over base version
  scope           String   @default("workspace") // workspace | project
  project_ids     String[] // if scope = project
  installed_at    DateTime @default(now())
  installed_by    String

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, pack_id])
  @@index([user_id])
}

// ─── Source Trust Log (Amendment 69) ─────────────────────────────────────────

model SourceTrustEvent {
  id          String   @id @default(uuid())
  run_id      String?
  user_id     String
  source_type String   // url | file | web_search | mcp_internal
  source_ref  String   // url or filename
  trust_level String   // VERIFIED | EXTERNAL | UNKNOWN | UNTRUSTED
  reason      String?  // why UNKNOWN/UNTRUSTED
  action      String   // allowed | blocked | warned
  created_at  DateTime @default(now())

  @@index([run_id])
  @@index([trust_level])
}

// ─── Git Worktrees — app_scaffolding (Amendment 60) ──────────────────────────

model GitWorktree {
  id          String    @id @default(uuid())
  run_id      String
  project_id  String
  project     Project   @relation(fields: [project_id], references: [id])
  layer       WorktreeLayer  // db | api | ui | infra | test
  branch_name String    // feat/{run_id}/{layer}
  path        String    // absolute on-disk path
  status      String    @default("active") // active | merged | cleaned
  created_at  DateTime  @default(now())
  merged_at   DateTime?
  cleaned_at  DateTime?

  @@index([run_id])
  @@index([project_id, status])
}

// ─── Event Payload Buffer (Amendment 79) ─────────────────────────────────────
// Stores large SSE events and acts as a 30s reconnect buffer for PgNotifyEventBus.
// Cleanup: daily cron DELETE WHERE expires_at < NOW(). Max payload: 64KB.

model EventPayload {
  id         String   @id @default(uuid())
  project_id String
  run_id     String
  payload    String   // full JSON — max 64KB
  created_at DateTime @default(now())
  expires_at DateTime // = created_at + EVENT_PAYLOAD_TTL_HOURS (default 24h)

  @@index([project_id, created_at])
}

// ─── Run Actor Stats (Amendment 80 — experimental) ───────────────────────────
// Cached stats for the "Actors ⚗" tab in Run detail view.
// Invalidated on any new AuditLog entry for the run.

model RunActorStats {
  id          String   @id @default(uuid())
  run_id      String   @unique
  run         Run      @relation(fields: [run_id], references: [id])
  stats       Json     // RunActorStats payload — computed lazily, cached
  computed_at DateTime @default(now())
}

// ─── Eval Results (Amendment 89) ─────────────────────────────────────────────

model EvalResult {
  id              String   @id @default(uuid())
  run_id          String
  run             Run      @relation(fields: [run_id], references: [id])
  node_id         String
  attempt         Int      // 1, 2, or 3
  overall_score   Float
  passed          Boolean
  criteria        Json     // EvalCriterion[] with individual scores
  feedback        String?
  computed_at     DateTime @default(now())
  // Populated when parallelEval() is used (Amendment 4.4 — cross-model validation)
  model_breakdown Json?    // ModelBreakdownItem[] per-model raw results

  @@index([run_id])
}

// ─── Preview Port Allocator (Amendment 73) ────────────────────────────────────
// Tracks which port (3100–3199) is claimed by which run during the smoke test.
// Released when the container is torn down (Human Gate resolution or run abandonment).

model PreviewPort {
  id           String   @id @default(uuid())
  port         Int      @unique
  run_id       String   @unique   // only one preview per run
  allocated_at DateTime @default(now())

  @@index([run_id])
}

// ─── Critical Reviewer (Amendment 75 / Section 27) ───────────────────────────
// Stores the structured output of the CriticalReviewer agent.
// Ignores and fixes are tracked in child tables for audit immutability.

model CriticalReviewResult {
  id         String   @id @default(uuid())
  run_id     String
  run        Run      @relation(fields: [run_id], references: [id])
  severity   Int      // 0–5
  verdict    String   // 'no_issues' | 'issues_found'
  findings   Json     // CriticalFinding[]
  suppressed Int      @default(0)
  rationale  String
  llm_used   String
  cost_usd   Decimal  @db.Decimal(10, 4)
  created_at DateTime @default(now())

  ignores CriticalFindingIgnore[]
  fixes   CriticalFindingFix[]

  @@index([run_id])
}

model CriticalFindingIgnore {
  id         String               @id @default(uuid())
  result_id  String
  result     CriticalReviewResult @relation(fields: [result_id], references: [id])
  finding_id String
  finding    Json                 // CriticalFinding snapshot
  ignored_by String               // user_id
  ignored_at DateTime             @default(now())
  // Immutable — also recorded in audit_log
}

model CriticalFindingFix {
  id         String               @id @default(uuid())
  result_id  String
  result     CriticalReviewResult @relation(fields: [result_id], references: [id])
  finding_id String
  fix_run_id String?              // run_id of the targeted fix agent run
  status     String               // 'pending' | 'fixed' | 'failed'
  cost_usd   Decimal              @db.Decimal(10, 4)
  created_at DateTime             @default(now())
}

// ─── LLM Provider Keys (credential vault) — Amendment 40.3 ──────────────────
// Encrypted with AES-256-GCM (same ENCRYPTION_KEY as ProjectCredential).
// Used when orchestrator.yaml: llm.credential_storage = vault.
// Default v1 mode (env) reads from process.env — this table is the migration path.

model LlmProviderKey {
  id           String    @id @default(uuid())
  provider     String    // 'anthropic' | 'openai' | 'google' | 'cometapi' | ...
  label        String    // human label: "Production Anthropic key"
  key_enc      String    // AES-256-GCM: gcm:<ivHex>:<ciphertextHex>:<tagHex>
  added_by     String    // user_id
  added_at     DateTime  @default(now())
  last_used_at DateTime?
  active       Boolean   @default(true)

  // One active key per provider — partial unique index in migration SQL.
  @@index([provider])
  @@map("LlmProviderKey")
}

// ─── System Settings — instance-wide key/value store ─────────────────────────
// Writable via PATCH /api/admin/security (instance_admin only).
// Readable via GET /api/instance/policy (public, non-sensitive values only).
// Env vars take precedence over DB values for security-critical settings.

model SystemSetting {
  key        String   @id       // e.g. 'security.mfa_required_for_admin'
  value      String             // JSON-encoded value (string, bool, number)
  updated_at DateTime @updatedAt
  updated_by String?            // user_id of last editor (null = seeded/migrated)
}

// ─── Pipeline Templates ───────────────────────────────────────────────────────
// User-defined reusable DAG definitions. Persisted, versioned, improvable via
// AI feedback loop. Instances referenced by Run.pipeline_template_id.

model PipelineTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  // null = global (visible to all instance users); non-null = scoped to project
  project_id  String?
  // RGPD Art.17: nullable — set to NULL when the creator's account is deleted
  // (rather than cascade-deleting the template, which may be a project resource).
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  is_public   Boolean  @default(false) // global templates only
  use_count   Int      @default(0)     // incremented on each run using this template

  // The canonical DAG definition: { nodes: DagNode[], edges: DagEdge[] }
  // Matches the existing Dag interface (types/dag.types.ts).
  dag         Json

  // Latest AI improvement suggestion (null = none yet)
  ai_suggestion     Json?    // { nodes, edges, rationale }
  ai_suggested_at   DateTime?

  creator   User?             @relation(fields: [created_by], references: [id], onDelete: SetNull)
  project   Project?          @relation(fields: [project_id], references: [id])
  versions  PipelineTemplateVersion[]
  runs      Run[]

  @@index([created_by])
  @@index([project_id])
}

// Append-only version history for PipelineTemplate.
// source = 'user' when the user manually edits the template.
// source = 'ai_suggestion' when the AI-proposed version is accepted.
model PipelineTemplateVersion {
  id          String   @id @default(uuid())
  template_id String
  version     Int      // monotonic, starts at 1
  dag         Json     // snapshot of the DAG at this version
  change_note String?  // human or AI rationale for the change
  source      String   @default("user") // 'user' | 'ai_suggestion'
  created_by  String
  created_at  DateTime @default(now())

  template    PipelineTemplate @relation(fields: [template_id], references: [id])

  @@unique([template_id, version])
  @@index([template_id])
}

// ─── GitHub Import Preview ────────────────────────────────────────────────────
// Staging row created by POST /api/admin/skills/from-url (single-file flow)
// and POST /api/admin/marketplace/… routes (repo/update flows — marketplace v2).
// Stores the content_sha256 / file_hashes at preview time so the approval step
// can detect if the remote file changed between preview and approve (SEC-10).
// Expires automatically — rows older than TTL are purged at each cron run.
model GitHubImportPreview {
  id              String   @id
  // Legacy single-file fields (from-url v1 flow)
  actor           String   // userId of the admin who initiated the preview
  source_url      String   // original GitHub raw URL
  content_sha256  String   // SHA-256 of content at preview time (SEC-10)
  scaffold        Json     // serialized GitHubImportPreview (all fields + inferred flags)
  // Marketplace v2 fields — nullable for backward compat with existing rows
  created_by      String?  // same as actor — used by v2 code for ownership checks
  file_hashes     Json?    // { "path/to/file.md": "sha256hex", ... } — multi-file support
  context         String?  // 'smart_import' | 'update_check' | 'git_import'
  created_at      DateTime @default(now())
  expires_at      DateTime // created_at + 24h — must be checked on approve

  @@index([actor])
  @@index([expires_at])
}

// ─── Marketplace v2: Git URL Whitelist ────────────────────────────────────────
// Controls which git hosts are allowed as import sources (SEC-01).

model GitUrlWhitelistEntry {
  id          String   @id @default(uuid())
  label       String   // human name, e.g. "Internal GitLab"
  pattern     String   // hostname or glob, e.g. "github.com" | "*.internal.corp"
  description String?
  is_builtin  Boolean  @default(false)
  enabled     Boolean  @default(true)
  created_by  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([pattern])
}

// ─── Marketplace v2: Remote Registry Feeds ────────────────────────────────────
// Configures remote marketplace registry URLs (B.1).

model MarketplaceRegistry {
  id                String    @id @default(uuid())
  label             String
  feed_url          String
  auth_header_enc   String?   // AES-256-GCM encrypted; never returned via API (SEC-14)
  is_builtin        Boolean   @default(false)
  enabled           Boolean   @default(true)
  last_fetched_at   DateTime?
  last_fetch_status String?   // "ok" | "error: <opaque code>"
  created_by        String
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@unique([feed_url])
}

// ─── Run Artifacts ────────────────────────────────────────────────────────────
// Files generated by PYTHON_EXECUTOR nodes and stored for download.
// Binary content stored as bytea (self-hosted: no external storage dependency).
// Artifacts are scoped to a run+node pair and expire after 90 days via cron.

model RunArtifact {
  id             String   @id @default(uuid())
  run_id         String
  node_id        String   // DAG node_id e.g. "n3"
  run            Run      @relation(fields: [run_id], references: [id], onDelete: Cascade)
  filename       String   // sanitised, e.g. "report.xlsx"
  mime_type      String   // from ALLOWED_MIME whitelist
  size_bytes     Int
  data           Bytes    // raw binary content
  created_at     DateTime @default(now())
  expires_at     DateTime // created_at + 90 days
  artifact_role  String   @default("pending_review")
  // Valeurs : "pending_review" | "primary" | "supplementary" | "discarded"

  @@index([run_id])
}

// ─── Marketplace v2: Git Provider Tokens ─────────────────────────────────────
// Per-host access tokens for private Git repositories (A.5).

model GitProviderToken {
  id           String    @id @default(uuid())
  label        String
  host_pattern String
  token_enc    String    // AES-256-GCM encrypted — never returned via API (SEC-46)
  enabled      Boolean   @default(true)
  expires_at   DateTime? // optional: admin-declared expiration date
  created_by   String
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@unique([host_pattern])
}
