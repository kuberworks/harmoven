# .env.test — CI test environment
# Used by: npm test, GitHub Actions pr.yml / main.yml
# Never commit real credentials here — all values are test-safe placeholders.

# Database — test-specific DB (separate from dev DB)
DATABASE_URL="postgresql://harmoven:harmoven@localhost:5432/harmoven_test"
DATABASE_PROVIDER="postgresql"

# Auth — deterministic test secrets
AUTH_SECRET="test-secret-do-not-use-in-production-32chars"
AUTH_URL="http://localhost:3000"
AUTH_DOMAIN="localhost"

# LLM — always mock in CI (0 real API calls, $0 cost)
HARMOVEN_LLM_TIER="mock"

# Credential vault — test key (not used for real encryption in tests)
ENCRYPTION_KEY="test-encryption-key-do-not-use-in-prod"

# Email — disabled in tests (magic link flow uses mock transport)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="test@harmoven.local"

# Deployment
DEPLOYMENT_MODE="docker"
NODE_ENV="test"
