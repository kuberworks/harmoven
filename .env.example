# .env.example — Harmoven v1
# Copy to .env and fill in your values. Never commit .env.
# Generate secrets with: openssl rand -base64 32

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL (Docker)
DATABASE_URL="postgresql://harmoven:CHANGE_ME@localhost:5432/harmoven"
# Internal URL used by the app container (service name = "db", port 5432 inside Docker):
# DATABASE_URL="postgresql://harmoven:CHANGE_ME@db:5432/harmoven"
# If port 5432 is already taken locally (e.g. another Postgres), set:
# HARMOVEN_DB_PORT=5433

# PostgreSQL credentials (must match docker-compose db service)
# SECURITY: use a strong password — never keep the default in production
POSTGRES_USER="harmoven"
POSTGRES_PASSWORD="CHANGE_ME"    # REQUIRED — openssl rand -base64 32
POSTGRES_DB="harmoven"

# SQLite (Electron only — uncomment and replace DATABASE_URL above)
# DATABASE_URL="file:./data/orchestrator.db"

DATABASE_PROVIDER="postgresql"    # postgresql | sqlite

# ─── Auth (Better Auth ≥1.3.26) ──────────────────────────────────────────────

AUTH_SECRET=""                    # REQUIRED — openssl rand -base64 32
AUTH_URL="http://localhost:3000"  # Full URL of the app (no trailing slash)
AUTH_DOMAIN="localhost"           # Domain for Passkeys rpId (no protocol, no port)

# OAuth2 providers (PKCE — enable per deployment)
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
# Add only the providers you use. Keys are stored in .env, NOT in the credential vault.
# The credential vault (ENCRYPTION_KEY below) is for project-level credentials injected
# into runs — not for the LLM keys used by the orchestrator itself.

ANTHROPIC_API_KEY=""              # https://console.anthropic.com
OPENAI_API_KEY=""                 # https://platform.openai.com/api-keys
GOOGLE_AI_API_KEY=""              # https://aistudio.google.com/app/apikey
MISTRAL_API_KEY=""                # https://console.mistral.ai
MINIMAX_API_KEY=""                # https://www.minimaxi.com

# CometAPI (OpenAI-compatible unified gateway — Am.71)
# COMETAPI_API_KEY=""             # https://cometapi.com

# Ollama (auto-detected if running locally — no key needed)
# OLLAMA_BASE_URL="http://localhost:11434"

# LLM tier for tests — controls which LLM client P8 uses in CI
HARMOVEN_LLM_TIER="mock"         # mock | haiku | sonnet

# ─── Email (magic link / notifications) ───────────────────────────────────────
# Option 1: SMTP
SMTP_HOST=""                      # e.g. smtp.resend.com
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""                     # e.g. harmoven@yourcompany.com

# Option 2: Resend API (simpler — comment SMTP vars above and use this)
# RESEND_API_KEY=""

# ─── Credential Vault ─────────────────────────────────────────────────────────
# CRITICAL: ENCRYPTION_KEY must NEVER be in the same secrets file/section as
# DATABASE_URL. If DATABASE_URL is compromised, ENCRYPTION_KEY must still be safe.

ENCRYPTION_KEY=""                 # REQUIRED if using project credentials — openssl rand -base64 32

# OneCLI secrets backend (alternative to internal vault — opt-in)
# ONECLI_AGENT_TOKEN=""
# ONECLI_ENCRYPTION_KEY=""        # Separate from main ENCRYPTION_KEY

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Upstash Redis (production) — falls back to in-memory for Electron
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ─── Temporal (enterprise execution engine — opt-in) ─────────────────────────
# TEMPORAL_ADDRESS="localhost:7233"
# TEMPORAL_NAMESPACE="harmoven"

# ─── LiteLLM proxy (unified provider gateway — opt-in) ───────────────────────
# LITELLM_PROXY_URL="http://localhost:4000"
# LITELLM_MASTER_KEY=""

# ─── Presidio PII detection (opt-in) ─────────────────────────────────────────
# PRESIDIO_ENDPOINT="http://localhost:5002"

# ─── n8n webhooks (opt-in) ────────────────────────────────────────────────────
# N8N_WEBHOOK_BASE_URL=""

# ─── LLM OAuth (per-provider — opt-in) ───────────────────────────────────────
# OPENAI_OAUTH_CLIENT_ID=""
# OPENAI_OAUTH_CLIENT_SECRET=""
# GOOGLE_OAUTH_CLIENT_ID=""
# GOOGLE_OAUTH_CLIENT_SECRET=""

# ─── Scaffolding agents ───────────────────────────────────────────────────────
# REQUIRED if SMOKE_TEST or REPAIR agents are enabled.
# All generated app worktrees must live under this directory.
# The path-traversal guard rejects any worktree path that escapes this prefix.
WORKTREE_BASE_DIR="/var/harmoven/worktrees"   # REQUIRED for scaffolding agents

# ─── Deployment overrides ─────────────────────────────────────────────────────
# DEPLOYMENT_MODE=""              # docker | electron (auto-detected if unset)
# ARGON2_MEMORY_KB=""             # 65536 (Docker default) | 19456 (Electron default)
